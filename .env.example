X3_DISCORD_TOKEN=YOUR_DISCORD_TOKEN
X3_GITHUB_TOKEN=YOUR_GITHUB_MARKETPLACE_TOKEN_OPTIONAL
# these can be separated with semicolons if you have multiple tokens/providers
X3_ZJ_TOKEN=YOUR_ZUKIJOUNRNEY_TOKEN_OPTIONAL
X3_GROQ_TOKEN=YOUR_GROQ_TOKEN_OPTIONAL
X3_GOOGLE_AISTUDIO_TOKEN=YOUR_GOOGLE_AISTUDIO_TOKEN_OPTIONAL
X3_OPENROUTER_TOKEN=YOUR_OPENROUTER_TOKEN_OPTIONAL
X3_G4F_TOKEN=secret
X3_CROF_TOKEN=YOUR_CROFAI_TOKEN_OPTIONAL
X3_ELECTRONHUB_TOKEN=YOUR_ELECTRONHUB_TOKEN_OPTIONAL
# if you have more than one cloudflare endpoint, provide urls and tokens for all
X3_CLOUDFLARE_API_BASE=https://subdomain.someusername.workers.dev/v1 # see https://github.com/chand1012/openai-cf-workers-ai
X3_CLOUDFLARE_API_TOKEN=YOUR_ACCESS_TOKEN_1
X3_COHERE_TOKEN=YOUR_COHERE_TOKEN_OPTIONAL
X3_MNN_TOKEN=YOUR_MNN_TOKEN_OPTIONAL
X3_VOIDAI_TOKEN=YOUR_VOIDAI_TOKEN_OPTIONAL
X3_BIGMODEL_TOKEN=YOUR_BIGMODEL_TOKEN_OPTIONAL
X3_CHUTES_TOKEN=YOUR_CHUTES_TOKEN_OPTIONAL
X3_CEREBRAS_TOKEN=YOUR_CEREBRAS_TOKEN_OPTIONAL
X3_TOGETHER_TOKEN=YOUR_TOGETHER_TOKEN_OPTIONAL
X3_NINETEEN_TOKEN=YOUR_NINETEEN_TOKEN_OPTIONAL
X3_HCAP_TOKEN=YOUR_HCAP_TOKEN_OPTIONAL
X3_POLLINATIONS_TOKEN=YOUR_POLLINATIONS_TOKEN_OPTIONAL
X3_TARGON_TOKEN=YOUR_TARGON_TOKEN_OPTIONAL
X3_ATLAS_TOKEN=YOUR_ATLAS_TOKEN_OPTIONAL
X3_HUGGINGFACE_TOKEN=YOUR_HUGGINGFACE_TOKEN_OPTIONAL
X3_AKASH_TOKEN=YOUR_AKASH_TOKEN_OPTIONAL
X3_LLM7_TOKEN=YOUR_LLM7_TOKEN_OPTIONAL
X3_LONGCAT_TOKEN=YOUR_LONGCAT_TOKEN_OPTIONAL
X3_PERPLEXITY_TOKEN=YOUR_PERPLEXITY_TOKEN_OPTIONAL
X3_ROUTEWAY_TOKEN=YOUR_ROUTEWAY_TOKEN_OPTIONAL
X3_MINIMAX_TOKEN=YOUR_MINIMAX_TOKEN_OPTIONAL
X3_OLLAMA_TOKEN=YOUR_OLLAMA_TOKEN_OPTIONAL
X3_VERCEL_TOKEN=YOUR_VERCEL_TOKEN_OPTIONAL
X3_KIVEST_TOKEN=YOUR_KIVEST_TOKEN_OPTIONAL
X3_AGENTROUTER_TOKEN=YOUR_AGENTROUTER_TOKEN_OPTIONAL
X3_ZENMUX_TOKEN=YOUR_ZENMUX_TOKEN_OPTIONAL
X3_DEEPSEEK_TOKEN=YOUR_DEEPSEEK_TOKEN_OPTIONAL
X3_GOTENBERG_URL=http://gotenberg:3000
X3_AIHORDE_API_KEY=0000000000 # will use "0000000000" if unset
X3_SELFHOSTED_API_BASE=http://localhost:8001/v1 # if you have ollama/llama-server/koboldcpp/etc running locally
X3_SELFHOSTED_API_TOKEN=secret
X3_LOG_LEVEL=debug
X3_ENABLE_SUMMARIES=false
X3_CONTINUATION_GRACE=20s
X3_CONTINUATION_WINDOW=10m
X3_MINILM_MODEL_PATH=models/minilm/all-MiniLM-L6-v2.onnx
X3_MINILM_ONNX_RUNTIME_LIB=/usr/lib/libonnxruntime.so.1
X3_MINILM_SIMILARITY=0.3

# Optional Matrix bot. Rebuild with `-tags goolm` (or Docker build arg
# `GO_BUILD_TAGS=goolm`) to enable the pure-Go Matrix E2EE backend.
X3_MATRIX_ENABLED=false
X3_MATRIX_HOMESERVER=https://matrix.example.org
X3_MATRIX_USER_ID=@x3:example.org

# Token mode: use an access token for a dedicated x3 Matrix device.
X3_MATRIX_ACCESS_TOKEN=YOUR_MATRIX_ACCESS_TOKEN

# Password mode: leave X3_MATRIX_ACCESS_TOKEN empty and x3 will log in and
# create/reuse a dedicated Matrix device in X3_MATRIX_CRYPTO_DB.
X3_MATRIX_USERNAME=
X3_MATRIX_PASSWORD=
X3_MATRIX_DEVICE_NAME=x3 bot

# Optional. In token mode, if omitted, x3 calls /whoami and uses the token's
# device ID. In password mode, if omitted, x3 reuses the device ID from the
# crypto DB or lets the homeserver create one on first login.
X3_MATRIX_DEVICE_ID=
X3_MATRIX_PICKLE_KEY=CHANGE_ME_TO_A_RANDOM_SECRET
X3_MATRIX_CRYPTO_DB=x3-matrix-crypto.db
# Optional. Set this to your Matrix recovery key to let the headless bot
# verify/cross-sign its own device on startup.
X3_MATRIX_RECOVERY_KEY=
X3_MATRIX_COMMAND_PREFIX=!x3
X3_MATRIX_AUTO_JOIN=true
